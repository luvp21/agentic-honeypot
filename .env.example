
HONEYPOT_API_KEY=your_api_key_here

# Google Gemini API key (from https://aistudio.google.com/app/apikey)
# Required for LLM-powered responses and intel extraction.
# If not set, the system falls back to rule-based responses only.
GEMINI_API_KEY=your_gemini_api_key_here

MAX_TURNS=10

PROCESSING_DELAY_SECONDS=3
